# Copy to .env (gitignored) and fill in. Read via: EnvironmentFile=%h/containers/gluetun/.env
# NOTE: Quadlet does NOT interpolate .env into unit directives. The keys below
# use gluetun's OWN env-var names, so they pass straight into the container.
# The published WebUI port is a unit directive, not an env var — set it in
# gluetun.pod's PublishPort= for each app riding this VPN.

# Timezone
TZ=Europe/Amsterdam

# --- ProtonVPN (WireGuard) ------------------------------------------------
# Proton portal -> Downloads -> WireGuard configuration. Pick a P2P server,
# enable "Moderate NAT" (required for port forwarding), generate, then copy
# ONLY the PrivateKey value here.
WIREGUARD_PRIVATE_KEY=

# Exit country/countries (comma-separated names). Switzerland = strong privacy
# jurisdiction + P2P + port forwarding.
SERVER_COUNTRIES=Switzerland

# Port forwarding — gluetun's port-forward-aware apps (e.g. qBittorrent via
# scripts/qbt-port.sh) need a P2P server above.
VPN_PORT_FORWARDING=on
PORT_FORWARD_ONLY=on

# gluetun firewall: allow return traffic to your LAN clients hitting any
# published WebUI in the pod (gluetun's native FIREWALL_OUTBOUND_SUBNETS —
# match your actual network, check `ip route`). Without it, WebUIs in this
# pod are unreachable from other machines.
FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24
