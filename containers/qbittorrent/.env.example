# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Read by qbittorrent.container via: EnvironmentFile=%h/containers/qbittorrent/.env
#
# VPN/firewall config (WIREGUARD_PRIVATE_KEY, SERVER_COUNTRIES, etc.) lives in
# ../gluetun/.env instead — gluetun is now shared VPN infrastructure, not
# qBittorrent-specific. See containers/gluetun/.env.example.
#
# NOTE: Quadlet does NOT interpolate .env into unit directives. The downloads
# path is a unit directive, not an env var — set it literally in
# qbittorrent.container: Volume=<downloads>:/downloads (default /data/downloads)

# Run qBittorrent as your host user so downloaded files stay readable.
# Find yours with:  id -u  and  id -g  (the pod's UserNS=keep-id maps these 1:1)
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Amsterdam
