# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Read by BOTH units via:  EnvironmentFile=%h/containers/qbittorrent/.env
#
# NOTE: Quadlet does NOT interpolate .env into unit directives. The keys below use
# gluetun's OWN env-var names, so they pass straight into the container. But the
# WebUI bind and downloads path are unit directives — set those literally:
#   gluetun.container    : PublishPort=8080:8080   (or 127.0.0.1:8080:8080 behind a proxy)
#   qbittorrent.container: Volume=<downloads>:/downloads  (default /data/downloads)

# Run qBittorrent as your host user so downloaded files stay readable.
# Find yours with:  id -u  and  id -g  (UserNS=keep-id maps these 1:1)
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Amsterdam

# --- ProtonVPN (WireGuard) ------------------------------------------------
# Proton portal -> Downloads -> WireGuard configuration. Pick a P2P server,
# enable "Moderate NAT" (required for port forwarding), generate, then copy
# ONLY the PrivateKey value here.
WIREGUARD_PRIVATE_KEY=

# Exit country/countries (comma-separated names). Switzerland = strong privacy
# jurisdiction + P2P + port forwarding.
SERVER_COUNTRIES=Switzerland

# Port forwarding — Proton supports it and torrents need it. "on" requires a
# port-forward-capable (P2P) server above.
VPN_PORT_FORWARDING=on

# Only ever pick a port-forward-capable (P2P) server.
PORT_FORWARD_ONLY=on

# gluetun firewall: allow return traffic to your LAN clients hitting the WebUI.
# (This is gluetun's native FIREWALL_OUTBOUND_SUBNETS — match your actual network,
# check `ip route`.) Without it, the WebUI is unreachable from other machines.
FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24
