# NetBird — WireGuard mesh VPN client. Registers this host as a NetBird peer.
# Install: cp netbird.container netbird-client.volume ~/.config/containers/systemd/
#          systemctl --user daemon-reload && systemctl --user start netbird
[Unit]
Description=NetBird mesh VPN client
Wants=network-online.target
After=network-online.target

[Container]
Image=docker.io/netbirdio/netbird:latest
ContainerName=NetBird
HostName=pi
AutoUpdate=registry

# --- security baseline ---
NoNewPrivileges=true
DropCapability=ALL
AddCapability=NET_ADMIN
# NET_RAW: NetBird needs raw sockets for ICMP-based connectivity checks.
# Without it: "Error: status failed: up wg interface: failed to create ipv4
# raw socket: socket: operation not permitted" (verified live).
AddCapability=NET_RAW
AddDevice=/dev/net/tun

# --- first registration only: uncomment, set the key, start once, then remove ---
# Environment=NB_SETUP_KEY=<your-setup-key>

# --- storage: registration state in a named volume (reused on recreate) ---
Volume=netbird-client.volume:/var/lib/netbird

[Service]
Restart=always

[Install]
WantedBy=default.target
