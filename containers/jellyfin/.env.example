# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Read by the unit via:  EnvironmentFile=%h/containers/jellyfin/.env
#
# NOTE: Quadlet does NOT interpolate .env into unit directives. Only TZ (and the
# script vars below) reach the container via this file. PUID/PGID and MEDIA_PATH
# are documented here for reference, but you must ALSO mirror them into
# jellyfin.container:  User=<PUID>:<PGID>  and  Volume=<MEDIA_PATH>:/data:ro.

# Run as your host user so files on the media disk stay readable.
# Find yours with:  id -u  and  id -g  (must equal User= in jellyfin.container)
PUID=1000
PGID=1000

# Timezone (this one DOES pass through to the container)
TZ=Europe/Amsterdam

# Host path where your media hard disk is mounted (via /etc/fstab). The unit
# bind-mounts this to /data read-only; mount at /data so host and container paths
# match. If you change it, also change Volume= in jellyfin.container.
MEDIA_PATH=/data

# --- Optional: used by scripts/ManageSubtitles.sh (the subtitle importer) ---
# Jellyfin API key so the script auto-scans the library after importing subs.
# Create one: Dashboard -> Advanced -> API Keys -> +   (blank = ask at prompt)
JELLYFIN_API_KEY=
# Override only if your setup differs from the defaults:
# JELLYFIN_URL=http://localhost:8096
# JELLYFIN_SHOWS=/data/jellyfin/Shows
